PORT=4000
NODE_ENV=development

# --- Bot HTTP API (POST /api/telegram/deliver) ---
TELEGRAM_BOT_TOKEN=

# --- MTProto user session (POST /api/telegram/deliver-mtproto) ---
# Create an app at https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Sessions live in config/mtproto-accounts.json (not in .env). Run: npm run mtproto:login
# Optional: TELEGRAM_MTPROTO_ACCOUNTS_FILE=path/to/accounts.json
# Optional: TELEGRAM_MTPROTO_ACCOUNTS_JSON=[...]  (e.g. Docker secret)

# Optional: lock browser origin instead of *
# CORS_ORIGIN=https://your-game-client.example
#
# Bot-blocked markets: responses echo `link` (and optional `telegramAppDeepLink` for t.me URLs).
#
# MTProto: numeric telegramUserId often fails for users outside your dialogs (no "input entity").
# Prefer optional body field telegramUsername (no @) — see Telethon entity docs:
# https://docs.telethon.dev/en/stable/concepts/entities.html
